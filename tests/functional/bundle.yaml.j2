default-base: {{ base }}

machines:
  "0":

applications:
  ubuntu:
    charm: ubuntu
    num_units: 1
    to:
      - "0"
{% if base == "ubuntu@20.04" %}
  grafana-agent:
    charm: grafana-agent
{% else %}
  opentelemetry-collector:
    charm: opentelemetry-collector
{% endif %}
    channel: 2/stable
  hardware-observer:
    charm: {{ charm }}
    options:
        redfish-disable: {{ redfish_disable }}

relations:
{% if base == "ubuntu@20.04" %}
- - grafana-agent:juju-info
  - ubuntu:juju-info
{% else %}
- - opentelemetry-collector:juju-info
  - ubuntu:juju-info
{% endif %}
- - hardware-observer:general-info
  - ubuntu:juju-info
